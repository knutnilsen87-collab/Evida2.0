# Advokat AI local development defaults

APP_ENV=local
DATA_REGION=EU
CUSTOMER_DATA_TRAINING_ALLOWED=false

DATABASE_URL=postgresql+asyncpg://advokat_ai:advokat_ai@localhost:5432/advokat_ai
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=advokat-ai-local
S3_REGION=eu-local

AUTH_PROVIDER=local
AI_PROVIDER=mock
OCR_PROVIDER=mock
STORAGE_PROVIDER=minio
MALWARE_SCANNER=mock

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
